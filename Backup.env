    local function CreateChatMessage(text, isUser, isCode)
        local msgFrame = Instance.new("Frame")
        msgFrame.Size = UDim2.new(0.9, 0, 0, 100)
        msgFrame.BackgroundColor3 = isUser and Theme.Primary or Theme.Surface
        msgFrame.BorderSizePixel = 0
        msgFrame.Parent = ChatScrollFrame
        
        if isUser then
            msgFrame.Position = UDim2.new(0.1, 0, 0, 0)
        end
        
        local msgCorner = Instance.new("UICorner")
        msgCorner.CornerRadius = UDim.new(0, 8)
        msgCorner.Parent = msgFrame
        
        local authorLabel = Instance.new("TextLabel")
        authorLabel.Size = UDim2.new(1, -20, 0, 20)
        authorLabel.Position = UDim2.new(0, 10, 0, 5)
        authorLabel.BackgroundTransparency = 1
        authorLabel.Text = isUser and ("You • " .. os.date("%H:%M")) or ("ShopAI • " .. os.date("%H:%M"))
        authorLabel.TextSize = 11
        authorLabel.TextColor3 = isUser and Color3.fromRGB(255, 255, 255) or Theme.TextSecondary
        authorLabel.Font = Enum.Font.GothamBold
        authorLabel.TextXAlignment = Enum.TextXAlignment.Left
        authorLabel.Parent = msgFrame
        
        if isCode then
            local codeBox = Instance.new("ScrollingFrame")
            codeBox.Size = UDim2.new(1, -20, 1, -35)
            codeBox.Position = UDim2.new(0, 10, 0, 25)
            codeBox.BackgroundColor3 = Theme.BackgroundSecondary
            codeBox.BorderSizePixel = 0
            codeBox.ScrollBarThickness = 4
            codeBox.ScrollBarImageColor3 = Theme.Primary
            codeBox.CanvasSize = UDim2.new(0, 0, 0, 0)
            codeBox.Parent = msgFrame
            
            local codeCorner = Instance.new("UICorner")
            codeCorner.CornerRadius = UDim.new(0, 6)
            codeCorner.Parent = codeBox
            
            local codeText = Instance.new("TextLabel")
            codeText.Size = UDim2.new(1, -10, 0, 0)
            codeText.Position = UDim2.new(0, 5, 0, 5)
            codeText.BackgroundTransparency = 1
            codeText.Text = text
            codeText.TextSize = 12
            codeText.TextColor3 = Theme.TextPrimary
            codeText.Font = Enum.Font.Code
            codeText.TextXAlignment = Enum.TextXAlignment.Left
            codeText.TextYAlignment = Enum.TextYAlignment.Top
            codeText.TextWrapped = true
            codeText.Parent = codeBox
            
            local textSize = TextService:GetTextSize(text, 12, Enum.Font.Code, Vector2.new(codeBox.AbsoluteSize.X - 20, math.huge))
            codeText.Size = UDim2.new(1, -10, 0, textSize.Y + 10)
            codeBox.CanvasSize = UDim2.new(0, 0, 0, textSize.Y + 20)
            msgFrame.Size = UDim2.new(0.9, 0, 0, math.min(300, textSize.Y + 60))
            
            local copyBtn = Instance.new("TextButton")
            copyBtn.Size = UDim2.new(0, 60, 0, 25)
            copyBtn.Position = UDim2.new(1, -70, 0, 5)
            copyBtn.BackgroundColor3 = Theme.Success
            copyBtn.Text = "Copy"
            copyBtn.TextSize = 11
            copyBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            copyBtn.Font = Enum.Font.GothamBold
            copyBtn.BorderSizePixel = 0
            copyBtn.Parent = codeBox
            
            local copyCorner = Instance.new("UICorner")
            copyCorner.CornerRadius = UDim.new(0, 6)
            copyCorner.Parent = copyBtn
            
            copyBtn.MouseButton1Click:Connect(function()
                if setclipboard then
                    setclipboard(text)
                    copyBtn.Text = "Copied!"
                    copyBtn.BackgroundColor3 = Theme.Info
                    task.wait(2)
                    copyBtn.Text = "Copy"
                    copyBtn.BackgroundColor3 = Theme.Success
                end
            end)
            
            local executeBtn = Instance.new("TextButton")
            executeBtn.Size = UDim2.new(0, 70, 0, 25)
            executeBtn.Position = UDim2.new(1, -140, 0, 5)
            executeBtn.BackgroundColor3 = Theme.Primary
            executeBtn.Text = "Execute"
            executeBtn.TextSize = 11
            executeBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            executeBtn.Font = Enum.Font.GothamBold
            executeBtn.BorderSizePixel = 0
            executeBtn.Parent = codeBox
            
            local execCorner = Instance.new("UICorner")
            execCorner.CornerRadius = UDim.new(0, 6)
            execCorner.Parent = executeBtn
            
            executeBtn.MouseButton1Click:Connect(function()
                local success, err = pcall(function()
                    loadstring(text)()
                end)
                
                if success then
                    NotificationSystem:Notify("Execution Success", "Script executed successfully!", "Success", 3)
                else
                    NotificationSystem:Notify("Execution Error", tostring(err), "Error", 5)
                end
            end)
            
        else
            local textLabel = Instance.new("TextLabel")
            textLabel.Size = UDim2.new(1, -20, 1, -30)
            textLabel.Position = UDim2.new(0, 10, 0, 25)
            textLabel.BackgroundTransparency = 1
            textLabel.Text = text
            textLabel.TextSize = 13
            textLabel.TextColor3 = isUser and Color3.fromRGB(255, 255, 255) or Theme.TextPrimary
            textLabel.Font = Enum.Font.Gotham
            textLabel.TextXAlignment = Enum.TextXAlignment.Left
            textLabel.TextYAlignment = Enum.TextYAlignment.Top
            textLabel.TextWrapped = true
            textLabel.Parent = msgFrame
            
            local textSize = TextService:GetTextSize(text, 13, Enum.Font.Gotham, Vector2.new(msgFrame.AbsoluteSize.X - 20, math.huge))
            msgFrame.Size = UDim2.new(0.9, 0, 0, textSize.Y + 40)
        end
        
        return msgFrame
    end
    
    local isProcessing = false
    
    local function ProcessMessage()
        if isProcessing then return end
        
        local userInput = InputBox.Text:gsub("^%s*(.-)%s*$", "%1")
        if userInput == "" then return end
        
        isProcessing = true
        InputBox.Text = ""
        
        CreateChatMessage(userInput, true, false)
        
        SendButton.BackgroundColor3 = Theme.TextTertiary
        SendButton.Text = "..."
        
        local loadingMsg = CreateChatMessage("Generating script with ShopAI...", false, false)
        
        task.spawn(function()
            local fullPayload = ChatHistory .. "\nUsuário: " .. userInput
            
            local success, res = pcall(function()
                return game:HttpPost(AI_LINK, HttpService:JSONEncode({prompt = fullPayload}))
            end)
            
            loadingMsg:Destroy()
            
            if success then
                local data = HttpService:JSONDecode(res)
                local code = data.code:gsub("Gemini", "ShopAI"):gsub("Google", "Apex Team")
                
                ChatHistory = ChatHistory .. "\nUsuário: " .. userInput .. "\nIA: [Generated Code]"
                table.insert(ConversationHistory, {
                    timestamp = os.time(),
                    user = userInput,
                    ai = code,
                    id = Utility.GenerateUUID()
                })
                
                CreateChatMessage(code, false, true)
                
                if UserSettings.AutoSave then
                    pcall(function()
                        game:HttpPost(FIREBASE_URL .. "conversations/" .. Player.UserId .. ".json", 
                            HttpService:JSONEncode(ConversationHistory))
                    end)
                end
                
                NotificationSystem:Notify("Script Generated", "ShopAI generated your script!", "Success", 3)
            else
                CreateChatMessage("Failed to connect to Apex servers. Please try again.", false, false)
                NotificationSystem:Notify("Connection Error", "Failed to reach ShopAI service.", "Error", 4)
            end
            
            SendButton.BackgroundColor3 = Theme.Primary
            SendButton.Text = "➤"
            isProcessing = false
        end)
    end
    
    SendButton.MouseButton1Click:Connect(ProcessMessage)
    
    InputBox.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            ProcessMessage()
        end
    end)
    
    NotificationSystem:Notify("Welcome!", "ShopAI is ready to generate scripts for you.", "Success", 3)
end

StartApex()
