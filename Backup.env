        if isMinimized then
            TweenService:Create(MainWindow, TweenInfo.new(0.3, Enum.EasingStyle.Quad), {
                Size = UDim2.new(originalSize.X.Scale, originalSize.X.Offset, 0, 50)
            }):Play()
