local loadingSteps = {
    {text = "Connecting to Apex GitHub Repository...", progress = 0.2, duration = 0.8},
    {text = "Establishing secure connection to Firebase...", progress = 0.4, duration = 1.0},
    {text = "Initializing Google App Script tunnel...", progress = 0.6, duration = 1.0},
    {text = "Loading AI neural network models...\n[Engine: Gemini 2.0 Flash]", progress = 0.8, duration = 1.0},
    {text = "ShopAI initialization complete.\nReady to generate scripts.", progress = 1.0, duration = 0.5, color = Theme.Success}
}

local function StartApex()
    local currentStep = 1
    
    local function processStep()
        if currentStep > #loadingSteps then
            task.wait(0.5)
            StatusLabel.Text = "Welcome, " .. Player.Name .. "!"
            StatusLabel.TextColor3 = Theme.Success
            
            task.wait(1)
            AnimationSystem:FadeOut(MainFrame, 0.3, function()
                LoadingGui:Destroy()
                CreateMainInterface()
            end)
            return
        end
        
        local step = loadingSteps[currentStep]
        
        StatusLabel.Text = step.text
        StatusLabel.TextColor3 = step.color or Theme.TextSecondary
        
        TweenService:Create(
            ProgressFill,
            TweenInfo.new(step.duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out),
            {Size = UDim2.new(step.progress, 0, 1, 0)}
        ):Play()
        
        task.wait(step.duration)
        currentStep = currentStep + 1
        processStep()
    end
    
    print("Getting version: " .. VERSION_URL)
    
    local success, version = pcall(function()
        return game:HttpGet(VERSION_URL)
    end)
    
    if success then
        print("Version " .. version:gsub("%s+", "") .. " confirmed.")
        processStep()
    else
        StatusLabel.Text = "Connection Timeout."
        StatusLabel.TextColor3 = Theme.Error
        ProgressFill.BackgroundColor3 = Theme.Error
        
        task.wait(3)
        LoadingGui:Destroy()
        NotificationSystem:Notify("Connection Error", "Failed to connect.", "Error", 5)
    end
end

